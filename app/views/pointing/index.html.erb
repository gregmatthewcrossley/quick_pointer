<div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 p-2 sm:p-4" data-controller="pointing">
  <div class="max-w-2xl mx-auto">
    <header class="text-center mb-4 pt-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-800 mb-2">Quick Pointer</h1>
      <div class="inline-flex items-center gap-2 text-xs sm:text-sm text-gray-600 bg-white/80 px-3 py-1 rounded-full shadow-sm">
        <span class="inline-block w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
        <span id="presence-count"><%= @presence_count == 1 ? "1 person here" : "#{@presence_count} people here" %></span>
      </div>
    </header>

    <%= render partial: "session", locals: { session_data: @session_data, user_vote: @user_vote } %>

  </div>
</div>